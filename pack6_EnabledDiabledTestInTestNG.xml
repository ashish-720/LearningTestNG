<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="TestingAnnotationsSuite">
    <parameter name="url" value="https://opensource-demo.orangehrmlive.com/web/index.php/auth/login"></parameter>
    <parameter name="sleepValue" value="3000"></parameter>
    <test name="VerifyLogin" enabled="false">
        <classes>
            <class name="pack6_EnabledDisabledTestInTestNG.EnabledAndDisabledTestConcept">
                <methods>
                    <include name="navigateToApp"/>
                    <include name="loginToApp"/>
                    <include name="verifyLogin"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="VerifyAddEmployeeTab">
        <classes>
            <class name="pack6_EnabledDisabledTestInTestNG.EnabledAndDisabledTestConcept">
                <methods>
                    <include name="navigateToApp"/>
                    <include name="loginToApp"/>
                    <include name="verifyLogin"/>
                    <include name="addEmployee"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>