<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="TestingAnnotationsSuite">
    <parameter name="browserName" value="Chrome"></parameter>
    <parameter name="url" value="https://opensource-demo.orangehrmlive.com/web/index.php/auth/login"></parameter>
    <parameter name="sleepValue" value="3000"></parameter>
    <test name="VerifyLogin">
        <parameter name="browserName" value="firefox"></parameter>
        <parameter name="username" value="Admin"></parameter>
        <parameter name="password" value="admin123"></parameter>
        <classes>
            <class name="pack5_ParametersInTestNG.ParametersConceptInTestNG_UsingOrangeHRM">
                <methods>
                    <include name="navigateToApp"/>
                    <include name="loginToApp"/>
                    <include name="verifyLogin"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="VerifyAddEmployeeTab">
        <parameter name="username" value="Admin"></parameter>
        <parameter name="password" value="admin123"></parameter>
        <classes>
            <class name="pack5_ParametersInTestNG.ParametersConceptInTestNG_UsingOrangeHRM">
                <methods>
                    <include name="navigateToApp"/>
                    <include name="loginToApp"/>
                    <include name="verifyLogin"/>
                    <include name="addEmployee"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>