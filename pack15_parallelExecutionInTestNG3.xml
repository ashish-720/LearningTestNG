<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="All Test Suite" parallel="methods" thread-count="2">
    <!--Here test1->TestClass1, TestClass2, TestClass3 which contains 12 methods ->12 methods in the test1 will be executed using two threads
        then test2->4 methods will be executed using two threads-->
    <test name="test1">
        <classes>
            <class name="pack15_parallelExecutionInTestNG.TestClass1"/>
            <class name="pack15_parallelExecutionInTestNG.TestClass2"/>
            <class name="pack15_parallelExecutionInTestNG.TestClass3"/>
        </classes>
    </test>
    <test name="test2">
        <classes>
            <class name="pack15_parallelExecutionInTestNG.TestClass4"></class>
        </classes>
    </test>
</suite>