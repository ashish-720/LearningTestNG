<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<!--To execute the tests in sequential even though using parallel attribute-->
<!--In the below three cases sequential execution will take place and only one thread will be used-->
<!--<suite name="All Test Suite" parallel="false" thread-count="2">-->
<!--<suite name="All Test Suite" parallel="none" thread-count="2">-->
<!--<suite name="All Test Suite" parallel="tests" thread-count="1">-->
<!--<suite name="All Test Suite" parallel="tests" thread-count="-1"> will give illegalArgument Exception-->

<!--To execute the tests in parallel.
Here at first two tests will get executed in parallel test1,test2(as we have only two threads get created) and test3 has to wait
then once among test1, test2 whom so ever will be done its thread will be allocated to test3-->
<!--When one test occupy one thread then it will run sequentially on that thread-->
<!--parallel="tests" will always for suite level where it make sense-->
<suite name="All Test Suite" parallel="tests" thread-count="2">
    <test name="test1">
        <classes>
            <class name="pack15_parallelExecutionInTestNG.TestClass1"/>
        </classes>
    </test>
    <test name="test2">
        <classes>
            <class name="pack15_parallelExecutionInTestNG.TestClass2"/>
        </classes>
    </test>
    <test name="test3">
        <classes>
            <class name="pack15_parallelExecutionInTestNG.TestClass3"/>
        </classes>
    </test>
</suite>